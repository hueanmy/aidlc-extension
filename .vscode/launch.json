{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run AIDLC Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js",
        "${workspaceFolder}/packages/*/dist/**/*.js"
      ],
      "preLaunchTask": "npm: compile"
    }
  ]
}
