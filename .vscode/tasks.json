{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm: compile-all",
      "type": "shell",
      "command": "pnpm -r compile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "pnpm: watch-extension",
      "type": "shell",
      "command": "pnpm --filter ./packages/extension watch",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"],
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
