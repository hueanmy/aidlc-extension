{
  "name": "aidlc",
  "displayName": "AIDLC",
  "description": "Drive Claude through any pipeline declared in workspace.yaml — agents, skills, pipelines, and epics with sequential approve/reject/rerun runs, all from VS Code.",
  "version": "0.8.6",
  "publisher": "hueanmy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aidlc-io/aidlc"
  },
  "icon": "media/icon.png",
  "keywords": [
    "ai",
    "agents",
    "claude",
    "workflow",
    "automation",
    "pipeline",
    "workspace"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aidlc",
          "title": "AIDLC",
          "icon": "media/pipeline-icon.svg"
        }
      ]
    },
    "views": {
      "aidlc": [
        {
          "id": "aidlcSidebar",
          "name": "Workspace",
          "icon": "media/pipeline-icon.svg",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "aidlc.openBuilder",
        "title": "Open Workspace Builder",
        "icon": "$(layout-panel)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.showWorkspaceConfig",
        "title": "Show Workspace Config",
        "icon": "$(file-code)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.initWorkspace",
        "title": "Init Sample Workspace",
        "icon": "$(rocket)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.addSkill",
        "title": "Add Skill (template / paste / upload / blank)",
        "icon": "$(file-code)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.addAgent",
        "title": "Add Agent",
        "icon": "$(person)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.addPipeline",
        "title": "Add Pipeline (chain agents)",
        "icon": "$(list-ordered)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.openClaudeTerminal",
        "title": "Open Claude CLI Terminal",
        "icon": "$(terminal)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.savePreset",
        "title": "Save Workspace as Template",
        "icon": "$(save)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.applyPreset",
        "title": "Load Template",
        "icon": "$(symbol-snippet)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.deletePreset",
        "title": "Delete Saved Template",
        "icon": "$(trash)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.migrateEpics",
        "title": "Migrate Epic State Files",
        "icon": "$(sync)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.startEpic",
        "title": "Start Epic",
        "icon": "$(rocket)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.openEpicsList",
        "title": "Open Epics List",
        "icon": "$(checklist)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.insertDemoEpic",
        "title": "Insert Demo Epic (EPIC-100)",
        "icon": "$(beaker)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.loadDemoProject",
        "title": "Load Demo Project (full pipeline + 6 epics)",
        "icon": "$(beaker)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.showTokenUsage",
        "title": "Show Claude Token Usage",
        "icon": "$(graph)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.refreshTokenUsage",
        "title": "Refresh Claude Token Usage",
        "icon": "$(refresh)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.astGraph.openReport",
        "title": "Open AST Graph Report",
        "icon": "$(type-hierarchy)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.astGraph.rescan",
        "title": "Rescan AST Graph (clean)",
        "icon": "$(refresh)",
        "category": "AIDLC"
      },
      {
        "command": "aidlc.astGraph.reregisterMcp",
        "title": "Re-register AST Graph MCP Server",
        "icon": "$(plug)",
        "category": "AIDLC"
      }
    ],
    "configuration": {
      "title": "AIDLC",
      "properties": {
        "aidlc.tokenMonitor.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a status bar item with today/this-month Claude token spend, parsed from ~/.claude/projects logs."
        },
        "aidlc.tokenMonitor.refreshSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 15,
          "description": "How often to re-scan ~/.claude/projects for new usage records (seconds, minimum 15)."
        },
        "aidlc.tokenMonitor.suggestionWindowDays": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "Window the cost-suggestion engine scans (in days). Older logs are skipped — they don't reflect current habits."
        },
        "aidlc.astGraph.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Auto-download the ast-graph CLI, scan the workspace in the background, and register it as a Claude MCP server so Claude can read structural code context cheaply."
        },
        "aidlc.astGraph.autoRescanDebounceSeconds": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Debounce window for incremental rescans after source files change (seconds)."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "aidlc.openBuilder",
          "when": "view == aidlcSidebar",
          "group": "navigation@0"
        },
        {
          "command": "aidlc.openEpicsList",
          "when": "view == aidlcSidebar",
          "group": "navigation@1"
        },
        {
          "command": "aidlc.openClaudeTerminal",
          "when": "view == aidlcSidebar",
          "group": "navigation@2"
        },
        {
          "command": "aidlc.astGraph.openReport",
          "when": "view == aidlcSidebar",
          "group": "navigation@3"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "aidlc.gettingStarted",
        "title": "Get started with AIDLC",
        "description": "Drive Claude through any pipeline declared in workspace.yaml — visually, from the editor.",
        "steps": [
          {
            "id": "aidlc.welcome",
            "title": "Welcome to AIDLC",
            "description": "AIDLC turns a single `workspace.yaml` into a runnable pipeline of Claude agents — edit it visually, run epics step-by-step, approve or reject each handoff.\n\nThe fastest way to feel it is to load the demo project in the next step.",
            "media": {
              "markdown": "media/walkthrough/welcome.md"
            }
          },
          {
            "id": "aidlc.loadDemo",
            "title": "Load the demo project",
            "description": "One click scaffolds a full pipeline plus 6 sample epics into your current folder — no YAML to write.\n[Load Demo Project](command:aidlc.loadDemoProject)",
            "media": {
              "markdown": "media/walkthrough/demo.md"
            },
            "completionEvents": [
              "onCommand:aidlc.loadDemoProject"
            ]
          },
          {
            "id": "aidlc.builder",
            "title": "Open the Workspace Builder",
            "description": "Visual editor for your agents, skills, and pipelines. Add an agent, swap its model, edit a skill inline.\n[Open Workspace Builder](command:aidlc.openBuilder)",
            "media": {
              "markdown": "media/walkthrough/builder.md"
            },
            "completionEvents": [
              "onCommand:aidlc.openBuilder"
            ]
          },
          {
            "id": "aidlc.runEpic",
            "title": "Run your first epic",
            "description": "Pick a sample epic and watch Claude work through the pipeline. Approve, reject, or rerun any step.\n[Open Epics List](command:aidlc.openEpicsList) · [Start Epic](command:aidlc.startEpic)",
            "media": {
              "markdown": "media/walkthrough/epics.md"
            },
            "completionEvents": [
              "onCommand:aidlc.openEpicsList",
              "onCommand:aidlc.startEpic"
            ]
          },
          {
            "id": "aidlc.terminal",
            "title": "Drive runs from the terminal",
            "description": "One-click zsh terminal in the bottom panel with the Claude CLI auto-launched. Use slash commands or run `aidlc` directly.\n[Open Claude CLI Terminal](command:aidlc.openClaudeTerminal)",
            "media": {
              "markdown": "media/walkthrough/terminal.md"
            },
            "completionEvents": [
              "onCommand:aidlc.openClaudeTerminal"
            ]
          },
          {
            "id": "aidlc.buildYourOwn",
            "title": "Build your own workspace",
            "description": "Scaffold a fresh `.aidlc/workspace.yaml`, add custom skills/agents/pipelines, save the result as a reusable template.\n[Init Sample Workspace](command:aidlc.initWorkspace) · [Add Skill](command:aidlc.addSkill) · [Add Agent](command:aidlc.addAgent) · [Save as Template](command:aidlc.savePreset)",
            "media": {
              "markdown": "media/walkthrough/build.md"
            },
            "completionEvents": [
              "onCommand:aidlc.initWorkspace",
              "onCommand:aidlc.savePreset"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc -p ./ --noEmit && tsc -p ./tsconfig.webview.json --noEmit",
    "bundle:webviews": "vite build",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --format=cjs --outfile=out/extension.js",
    "bundle:prod": "esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --format=cjs --minify --outfile=out/extension.js",
    "clean:out": "rm -rf out",
    "package": "pnpm typecheck && pnpm clean:out && pnpm bundle:webviews && pnpm bundle:prod && vsce package --no-dependencies"
  },
  "dependencies": {
    "@aidlc/core": "workspace:*",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vscode/vsce": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.24.0",
    "lucide-react": "^0.453.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.3.0",
    "vite": "^7.3.3"
  }
}
