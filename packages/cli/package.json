{
  "name": "aidlc",
  "version": "0.1.0",
  "description": "AIDLC terminal CLI — drive workspace.yaml pipelines with Claude from any terminal.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aidlc-io/aidlc"
  },
  "homepage": "https://github.com/aidlc-io/aidlc#readme",
  "bugs": {
    "url": "https://github.com/aidlc-io/aidlc/issues"
  },
  "keywords": [
    "aidlc",
    "claude",
    "ai",
    "workflow",
    "sdlc",
    "agents",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/bundle.js",
  "bin": {
    "aidlc": "./dist/bundle.js"
  },
  "files": [
    "dist/bundle.js",
    "README.md"
  ],
  "scripts": {
    "compile": "tsc -p ./",
    "build": "tsc -p ./",
    "clean": "rm -rf dist",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/bundle.js --external:fsevents",
    "prepublishOnly": "pnpm bundle"
  },
  "dependencies": {
    "@aidlc/core": "workspace:*",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "cli-table3": "^0.6.5",
    "commander": "^11.1.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0"
  }
}
