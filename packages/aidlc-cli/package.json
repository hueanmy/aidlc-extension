{
  "name": "aidlc",
  "version": "0.1.0",
  "description": "AIDLC terminal CLI — drive your SDLC workflow from any terminal.",
  "license": "MIT",
  "bin": {
    "aidlc": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "dev": "node dist/index.js",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/bundle.js --external:fsevents",
    "build:binary:mac-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile=bin/aidlc-macos-arm64",
    "build:binary:mac-x64":   "bun build src/index.ts --compile --target=bun-darwin-x64   --outfile=bin/aidlc-macos-x64",
    "build:binary:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64    --outfile=bin/aidlc-linux-x64"
  },
  "dependencies": {
    "@aidlc/core": "*",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.3.0"
  }
}
