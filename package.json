{
  "name": "aidlc-flow",
  "displayName": "AIDLC Flow",
  "description": "AI-driven SDLC in VS Code, integrated with Claude Code, Jira, and Figma. Use slash commands /epic, /prd, /tech-design, /test-plan, /review, /release, /monitor to drive each phase by Jira epic key — pulling context from Jira tickets and Figma designs, with tree view and dashboard tracking status per epic.",
  "version": "0.7.1",
  "publisher": "aidlc-io",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aidlc-io/aidlc"
  },
  "icon": "media/icon.png",
  "keywords": [
    "sdlc",
    "pipeline",
    "epic",
    "agile",
    "project management",
    "tracker",
    "workflow"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:docs/sdlc/epics",
    "onStartupFinished",
    "onCommand:cfPipeline.refresh",
    "onCommand:cfPipeline.openDashboard",
    "onCommand:cfPipeline.selectEpicsFolder",
    "onCommand:cfPipeline.openSettings",
    "onCommand:cfPipeline.openArtifact",
    "onCommand:cfPipeline.runPhase",
    "onCommand:cfPipeline.openPhaseSession",
    "onCommand:cfPipeline.reviewGate",
    "onCommand:cfPipeline.openReview",
    "onCommand:cfPipeline.addFeedback",
    "onCommand:cfPipeline.advanceEpic",
    "onCommand:cfPipeline.runStep",
    "onCommand:cfPipeline.rerunStep",
    "onCommand:cfPipeline.feedbackAndRerun",
    "onCommand:cfPipeline.loadExampleProject",
    "onCommand:cfPipeline.clearExampleProject"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sdlc-pipeline",
          "title": "SDLC Pipeline",
          "icon": "media/pipeline-icon.svg"
        }
      ]
    },
    "views": {
      "sdlc-pipeline": [
        {
          "id": "cfPipelineView",
          "name": "Epic Pipeline",
          "icon": "media/pipeline-icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "cfPipelineView",
        "contents": "No SDLC epics yet.\n\nNew to AIDLC? Spin up a fully-bootstrapped example workspace (sample epic, agents, skills, schemas) to explore the pipeline end-to-end.\n[Load Example Project](command:cfPipeline.loadExampleProject)\n\nAlready have an MCP package?\n[Open Pipeline Settings](command:cfPipeline.openSettings)\n[Select Epics Folder](command:cfPipeline.selectEpicsFolder)"
      }
    ],
    "configuration": {
      "title": "SDLC Pipeline",
      "properties": {
        "cfPipeline.epicsPath": {
          "type": "string",
          "default": "docs/sdlc/epics",
          "description": "Relative path from workspace root to the SDLC epics folder."
        },
        "cfPipeline.templateSourcePath": {
          "type": "string",
          "default": "",
          "description": "Optional path to epic templates. Leave empty to use bundled templates shipped with this extension."
        },
        "cfPipeline.platform": {
          "type": "string",
          "default": "generic",
          "enum": [
            "mobile",
            "web",
            "backend",
            "desktop",
            "generic"
          ],
          "description": "Platform type passed to the MCP server as SDLC_PLATFORM env var. Extension itself ships no skills or agents — your MCP server decides what to load."
        },
        "cfPipeline.mcpPackage": {
          "type": "string",
          "default": "",
          "description": "MCP package spec (npm name or npx-compatible GitHub spec, e.g. 'github:owner/repo'). Leave empty to skip auto-config — extension will not install any MCP until you fill this in."
        },
        "cfPipeline.mcpServerName": {
          "type": "string",
          "default": "sdlc",
          "description": "MCP server key written into .claude/settings.json under mcpServers.<name>."
        },
        "cfPipeline.mcpCommand": {
          "type": "string",
          "default": "npx",
          "description": "MCP server command for Claude settings (for example: npx, uvx, node)."
        },
        "cfPipeline.mcpArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Optional MCP server args. If empty, extension uses ['-y', mcpPackage]."
        },
        "cfPipeline.mcpEnv": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "description": "Additional environment variables merged into MCP server env."
        },
        "cfPipeline.autoConfigureMcp": {
          "type": "boolean",
          "default": false,
          "description": "Automatically configure Claude Code MCP server on activation. Disabled by default — enable only after you have set cfPipeline.mcpPackage (or cfPipeline.mcpArgs) to your own MCP."
        }
      }
    },
    "commands": [
      {
        "command": "cfPipeline.refresh",
        "title": "Refresh Pipeline Status",
        "icon": "$(refresh)",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.openDashboard",
        "title": "Open Pipeline Dashboard",
        "icon": "$(dashboard)",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.selectEpicsFolder",
        "title": "Select Epics Folder",
        "icon": "$(folder-opened)",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.openSettings",
        "title": "Pipeline Settings",
        "icon": "$(gear)",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.openArtifact",
        "title": "Open Artifact",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.runPhase",
        "title": "Run Phase Command",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.openPhaseSession",
        "title": "Open Isolated Phase Session",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.reviewGate",
        "title": "Review Gate (Approve / Reject)",
        "icon": "$(bell-dot)",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.advanceEpic",
        "title": "Advance Epic (/advance-epic)",
        "icon": "$(play-circle)",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.runStep",
        "title": "Run Step",
        "icon": "$(play)",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.rerunStep",
        "title": "Re-run Step",
        "icon": "$(refresh)",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.feedbackAndRerun",
        "title": "Update Feedback + Re-run",
        "icon": "$(comment-discussion)",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.openReview",
        "title": "Open Review Panel (manual)",
        "icon": "$(eye)",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.addFeedback",
        "title": "Add Feedback Note",
        "icon": "$(comment)",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.loadExampleProject",
        "title": "Load Example Project",
        "icon": "$(rocket)",
        "category": "SDLC"
      },
      {
        "command": "cfPipeline.clearExampleProject",
        "title": "Clear Example Project",
        "icon": "$(trash)",
        "category": "SDLC"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cfPipeline.loadExampleProject",
          "when": "view == cfPipelineView && cfPipeline.empty",
          "group": "navigation@0"
        },
        {
          "command": "cfPipeline.selectEpicsFolder",
          "when": "view == cfPipelineView",
          "group": "navigation@1"
        },
        {
          "command": "cfPipeline.openSettings",
          "when": "view == cfPipelineView",
          "group": "navigation@2"
        },
        {
          "command": "cfPipeline.refresh",
          "when": "view == cfPipelineView",
          "group": "navigation@3"
        },
        {
          "command": "cfPipeline.openDashboard",
          "when": "view == cfPipelineView",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "cfPipeline.openPhaseSession",
          "when": "view == cfPipelineView && viewItem == phase",
          "group": "inline"
        },
        {
          "command": "cfPipeline.reviewGate",
          "when": "view == cfPipelineView && viewItem == phase-review",
          "group": "inline"
        },
        {
          "command": "cfPipeline.runStep",
          "when": "view == cfPipelineView && viewItem == phase-run",
          "group": "inline"
        },
        {
          "command": "cfPipeline.rerunStep",
          "when": "view == cfPipelineView && viewItem == phase-rerun",
          "group": "inline"
        },
        {
          "command": "cfPipeline.feedbackAndRerun",
          "when": "view == cfPipelineView && viewItem == phase-feedback",
          "group": "inline"
        },
        {
          "command": "cfPipeline.advanceEpic",
          "when": "view == cfPipelineView && viewItem == epic",
          "group": "inline"
        },
        {
          "command": "cfPipeline.addFeedback",
          "when": "view == cfPipelineView && viewItem =~ /^phase(-run|-rerun|-review|-feedback)?$/",
          "group": "inline@9"
        },
        {
          "command": "cfPipeline.openReview",
          "when": "view == cfPipelineView && viewItem =~ /^phase(-run|-rerun|-feedback)?$/",
          "group": "inline@8"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -b ./",
    "watch": "tsc -b -w ./",
    "package": "npm run compile && vsce package",
    "test": "npm run -w @aidlc/core test"
  },
  "dependencies": {
    "@aidlc/core": "*"
  },
  "bundledDependencies": [
    "@aidlc/core"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
