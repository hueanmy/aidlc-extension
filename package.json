{
  "name": "aidlc",
  "private": true,
  "description": "AIDLC monorepo — VS Code extension + core engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aidlc-io/aidlc"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "compile": "pnpm -r compile",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "package:extension": "pnpm --filter aidlc-flow package",
    "test": "pnpm --filter @aidlc/core test",
    "aidlc": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
